package RepeticaoFacaEnquanto;

import java.util.Scanner;

public class Ex63 {
    public static void main(String[] args) {
        Scanner entrada = new Scanner(System.in);

        boolean rodando = true;
        boolean primeiroNumero = true;

        int numeros = 0;
        int soma = 0;
        int menorNumero = numeros;
        int contador = 0;
        int contadorPares = 0;

        do{
            System.out.println("Escreva um número :");
            numeros = Integer.parseInt(entrada.nextLine());
            System.out.println("Quer continuar? [S/N]");
            char continuar = entrada.nextLine().toUpperCase().charAt(0);

            if (primeiroNumero){
                menorNumero = numeros;
                primeiroNumero = false;
            }else {
                if (numeros < menorNumero){
                    menorNumero = numeros;
                }
            }

            if( continuar == 'N'){
                rodando = false;
            }

            if (numeros%2 == 0){
                contadorPares++;
            }
            soma+=numeros;
            contador++;
        }while(rodando);

        int mediaValores=soma/contador;
        System.out.println("O somatório dos valores é :"+soma);
        System.out.println("O menor número digitado foi :"+menorNumero);
        System.out.println("A média dos valores é :"+mediaValores);
        System.out.println("A quantidade de números pares é :"+contadorPares);

  }
}

