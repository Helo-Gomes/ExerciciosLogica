//Exercicio 16 DESAFIO

Scanner entry = new Scanner(System.in);
        System.out.println("Quantos cigarros você fuma por dia? :");
        int cigarrosDia = entry.nextInt();
        System.out.println("Há quantos anos você fuma? :");
        int anosFumando = entry.nextInt();
        
        // cigarrosDia * 10 = minutos perdidos no dia 
        int minutosPerdidosDia = cigarrosDia * 10;
        // (1 ano = 365 dias) então -> anosFumando *365dias = dias fumados  
        int diasFumando = anosFumando * 365;
        //diasFumando * minutosPerdidosDia = quantidade de minutos perdidos no ano
        int minutosPerdidos = diasFumando * minutosPerdidosDia;
        // quantidade de minutos perdidos /60 = horasPerdidas
        int horasPerdidas = minutosPerdidos /60;
        // horasPerdidas/24 = dias de vida perdidos
        int diasPerdidos = horasPerdidas/24;
        
        System.out.println("Você perdeu "+diasPerdidos +" dias de vida por conta do uso de cigarros.");

