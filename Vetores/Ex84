package Vetores;

import java.util.Scanner;

public class Ex84 {
    public static void main(String[] args) {
        /*84) Crie um programa que leia o nome e a idade de 9 pessoas e guarde esses
            valores em dois vetores, em posições relacionadas. No final, mostre uma listagem
            contendo apenas os dados das pessoas menores de idade.*/

        Scanner entrada = new Scanner(System.in);
        String[] nome = new String[9];
        int [] idade = new int[9];

        for (int i = 0; i < idade.length; i++) {
            System.out.println("Qual o nome da "+i+"ª pessoa.");
            nome[i] = entrada.nextLine();
            System.out.println("Qual a idade da "+i+" ª pessoa");
            idade[i] = Integer.parseInt(entrada.nextLine());

        }
        System.out.println("As pessoas menores de idade são: ");
        for (int i = 0; i < idade.length; i++) {
            if(idade[i] < 18){
                System.out.println("Nome: "+nome[i]+" Idade: "+idade[i]);
            }
        }

    }
}
