package Vetores;

import java.util.Arrays;

public class Ex83 {
    public static void main(String[] args) {
        /*83) [DESAFIO] Crie uma lógica que preencha um vetor de 20 posições com números
        aleatórios (entre 0 e 99) gerados pelo computador. Logo em seguida, mostre os
        números gerados e depois coloque o vetor em ordem crescente, mostrando no final
        os valores ordenados.*/

        int [] vetorNumeros = new int[20];
        int numeroAleatorio = 0;
        for (int i = 0; i < vetorNumeros.length; i++) {
            numeroAleatorio = (int) (Math.random() * (99)); //gerar a cada loop
            vetorNumeros[i] = numeroAleatorio;
        }
        for (int i = 0; i < vetorNumeros.length; i++) {
            System.out.print(vetorNumeros[i]+" ");
        }
        Arrays.sort(vetorNumeros);
        System.out.println();
        System.out.print(Arrays.toString(vetorNumeros));

    }
}
