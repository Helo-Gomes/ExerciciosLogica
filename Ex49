import java.util.Scanner;
public class Main {
    
    public static void main(String[] args) {
        /*48) Faça um programa que leia
        7 números inteiros e no final
        mostre o somatório entre eles.*/
        
        Scanner teclado = new Scanner(System.in);
        
       int contador = 1;
      int  somaP = 0;
      int somaI =0;  
        while(contador<=6){
            System.out.print("Escreva o "+contador+" numero");
            int numero = teclado.nextInt();
            contador++;
            if(numero%2==0){
                somaP += numero;
                
            }else{
                somaI += numero;
              
            }
            
        }
          System.out.print("A soma dos impares é :"+somaI);
        System.out.print("A soma dos pares é :"+somaP);
    }
        
    
}
